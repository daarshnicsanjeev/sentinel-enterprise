# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.so
*.dylib

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
.env
*.env
!backend/.env.example

# ── Pytest / coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── SQLite databases (runtime data, not source) ───────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Node / frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/sentinel-ui/dist/
frontend/sentinel-ui/.vite/

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Terraform state (contains secrets — never commit) ────────────────────────
infra/.terraform/
infra/terraform.tfstate
infra/terraform.tfstate.backup
infra/.terraform.lock.hcl
infra/terraform.tfvars

# ── Docker ────────────────────────────────────────────────────────────────────
.dockerignore

# ── Sentence-transformers / HuggingFace model cache ──────────────────────────
backend/models/
~/.cache/huggingface/

# ── Ollama model data (large binary blobs) ────────────────────────────────────
ollama_data/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── SSH / TLS keys (NEVER commit private keys) ───────────────────────────────
*.pem
*.key
*.p12
*.pfx

# ── Frontend env files (contain EC2 IP / API URLs — set via CI secrets) ──────
frontend/sentinel-ui/.env.local
frontend/sentinel-ui/.env.production
frontend/sentinel-ui/.env.*.local

# ── Runtime feedback data (append-only logs, not source) ─────────────────────
backend/data/correction_examples.jsonl
backend/data/few_shot_examples.jsonl

# ── Duplicate / temp artifacts ────────────────────────────────────────────────
"sample_docs - Copy*/
sample_docs - Copy/
*.zip
# Demo ZIPs shipped with the repo for documentation / demo purposes
!sample_docs\ batch\ demo.zip
!sample_docs\ feedback\ loop\ demo.zip
!sample_docs/batch_demo.zip
!sample_docs/feedback_loop_demo.zip
