# ── LLM Configuration ──────────────────────────────────────────────────────────
# Only "ollama" provider is supported. Set OLLAMA_BASE_URL to your Ollama Cloud
# endpoint in production; leave empty to use local Ollama on localhost:11434.
LLM_PROVIDER=ollama
OLLAMA_MODEL=gemma4:31b-cloud
OLLAMA_BASE_URL=

# ── API Security ────────────────────────────────────────────────────────────────
# Optional. When set, all /api/* requests require this header:
#   X-API-Key: <value>
# Leave empty to disable key enforcement (development only).
SENTINEL_API_KEY=

# ── Rate Limiting ───────────────────────────────────────────────────────────────
# Maximum analyze requests per minute per IP address.
RATE_LIMIT=10

# ── Evaluation Threshold ────────────────────────────────────────────────────────
# Faithfulness score (0.0–1.0) below which the pipeline retries compliance check.
EVAL_THRESHOLD=0.7

# ── Routing Confidence Threshold ────────────────────────────────────────────────
# Router classification confidence (0.0–1.0) below which the final verdict is
# forced to ESCALATE for human review (the clause set may be wrong entirely).
ROUTING_CONFIDENCE_THRESHOLD=0.5

# ── Vector Store Backend ────────────────────────────────────────────────────────
# VECTOR_STORE=faiss        (default) — in-process FAISS, cached to disk by SHA-256.
#                           No external service required. Best for single-instance demo.
# VECTOR_STORE=opensearch   — Amazon OpenSearch Service (t2.small.search, free tier 12 mo.)
#                           Persistent, distributed. Requires OPENSEARCH_* vars below.
VECTOR_STORE=faiss

# OpenSearch connection (only needed when VECTOR_STORE=opensearch)
# For local Docker: OPENSEARCH_HOST=localhost, OPENSEARCH_PORT=9200
# For AWS OpenSearch Service: set HOST to the endpoint from the AWS console,
#   PORT=443, USE_SSL=true, and the master user credentials below.
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_USE_SSL=false

# ── AI Feedback Loop ────────────────────────────────────────────────────────────
# Minimum number of negative feedback entries per doc type before the review
# agent will call the LLM to analyse patterns. Set to 1 for demo (any single 👎
# immediately produces a recommendation). Raise to 3–5 in production to avoid
# noise from isolated mis-ratings.
REVIEW_MIN_EVIDENCE=1
